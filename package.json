{
  "name": "electerm",
  "version": "1.0.0",
  "description": "Terminal/ssh/sftp client based on electron/ssh2/node-pty/xterm/antd",
  "main": "work/app.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "node scripts/build.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "webpack": "cross-env NODE_ENV=development webpack --config webpack.config.js --watch",
    "webpack:prod": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "terminal",
    "ssh",
    "sftp",
    "electron",
    "xterm"
  ],
  "author": "electerm contributors",
  "license": "MIT",
  "dependencies": {
    "antd": "^5.0.0",
    "electron-context-menu": "^3.6.1",
    "electron-updater": "^6.1.4",
    "lodash": "^4.17.21",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ssh2": "^1.14.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.15",
    "babel-loader": "^9.1.3",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.52.0",
    "eslint-plugin-react": "^7.33.2",
    "jest": "^29.7.0",
    "less": "^4.2.0",
    "less-loader": "^11.1.3",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testTimeout": 30000
  },
  "build": {
    "appId": "io.electerm.electerm",
    "productName": "electerm",
    "files": [
      "work/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "build-assets"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "TerminalEmulator"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
